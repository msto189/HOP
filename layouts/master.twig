<!doctype html>
<html lang="{{ store.locale.code|default('en') }}" dir="{{ store.locale.is_rtl ? 'rtl' : 'ltr' }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% block title %}{{ store.name|default('Store') }}{% endblock %}</title>
    <meta name="description" content="{{ store.description|default('Premium dark Salla theme') }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="{{ 'assets/css/theme.css'|asset }}" />
    {% block head %}{% endblock %}
  </head>
  <body class="theme-dark">
    {% include 'partials/header.twig' %}
    <main id="main-content">
      {% block content %}{% endblock %}
    </main>
    {% include 'partials/footer.twig' %}
    <script defer src="{{ 'assets/js/theme.js'|asset }}"></script>
    {% block scripts %}{% endblock %}
  </body>
</html>
