{% extends "layouts/master.twig" %}

{% block title %}{{ product.name|default('Product') }} | {{ store.name|default('Store') }}{% endblock %}

{% block content %}
  <section class="section product-section">
    <div class="container product-layout">
      <div class="product-gallery">
        <img
          loading="eager"
          src="{{ product.images[0].url|default('https://images.unsplash.com/photo-1529139574466-a303027c1d8b?q=80&w=1600&auto=format&fit=crop') }}"
          alt="{{ product.name|default('Product') }}"
        />
      </div>
      <div class="product-info">
        <p class="eyebrow">LIMITED RELEASE</p>
        <h1 class="product-title">{{ product.name|default('Oversized Hoodie') }}</h1>
        <p class="product-price">{{ product.price|default('$180.00') }}</p>
        <p class="product-description">{{ product.description|default('Built with premium materials and elevated minimal design language.') }}</p>

        <form class="product-form" method="post" action="{{ product.add_to_cart_url|default('#') }}">
          <label for="qty" class="visually-hidden">Quantity</label>
          <input id="qty" type="number" min="1" value="1" class="qty-input" />
          <button class="btn-primary" type="submit">Add To Cart</button>
        </form>
      </div>
    </div>
  </section>
{% endblock %}
