{% extends 'layouts/master' %}
{% block content %}
<div class="hop-collection">
    <div class="hop-container">
        <div class="hop-collection__head">
            <h1 class="hop-collection__title">{{ category.name ?? trans('general.all_products') }}</h1>
            {% if category.description %}<p class="hop-collection__desc">{{ category.description }}</p>{% endif %}
        </div>
        <div class="hop-collection__toolbar">
            <button class="hop-filter-toggle" id="filter-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
                {{ trans('product.filter') }}
            </button>
            <span class="hop-collection__count">{{ pagination.total }} {{ trans('product.items') }}</span>
            <salla-sort-by>
                <select name="sort" class="hop-sort" aria-label="{{ trans('product.sort') }}">
                    <option value="">{{ trans('product.sort') }}</option>
                    <option value="newest">{{ trans('product.newest') }}</option>
                    <option value="price_low">{{ trans('product.price_low') }}</option>
                    <option value="price_high">{{ trans('product.price_high') }}</option>
                </select>
            </salla-sort-by>
        </div>
        <div class="hop-collection__body">
            <aside class="hop-filters" id="hop-filters" aria-hidden="true">
                <div class="hop-filters__head">
                    <h2>{{ trans('product.filter') }}</h2>
                    <button id="filter-close" aria-label="close">&#x2715;</button>
                </div>
                <salla-filters>{{ filters }}</salla-filters>
            </aside>
            <div class="hop-products-grid" id="products-grid">
                {% if products is empty %}
                <p class="hop-empty">{{ trans('general.no_results') }}</p>
                {% else %}
                {% for product in products %}
                    {% include 'partials/product/card' %}
                {% endfor %}
                {% endif %}
            </div>
        </div>
        {% if pagination.total_pages > 1 %}
        <div class="hop-pagination">
            <salla-pagination>{{ pagination_html }}</salla-pagination>
        </div>
        {% endif %}
    </div>
</div>
<div class="hop-overlay" id="filter-overlay"></div>
{% endblock %}
