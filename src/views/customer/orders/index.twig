{% extends 'layouts/master' %}
{% block content %}
<div class="hop-account">
    <div class="hop-container">
        <div class="hop-account__layout">
            {% include 'customer/sidebar' %}
            <div class="hop-account__main">
                <h1 class="hop-page-title">{{ trans('customer.orders') }}</h1>
                {% if orders is empty %}
                <p class="hop-empty">{{ trans('orders.empty') }}</p>
                {% else %}
                <div class="hop-orders">
                    {% for order in orders %}
                    <div class="hop-order-row">
                        <span>#{{ order.reference_id }}</span>
                        <span>{{ order.date }}</span>
                        <span class="hop-order-status hop-order-status--{{ order.status.slug }}">{{ order.status.name }}</span>
                        <span>{{ order.amounts.total.formatted }}</span>
                        <a href="{{ store.url }}/customer/orders/{{ order.id }}" class="hop-btn hop-btn--sm hop-btn--outline">{{ trans('orders.view') }}</a>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
