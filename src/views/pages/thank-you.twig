{% extends 'layouts/master' %}
{% block content %}
<div class="hop-thankyou">
    <div class="hop-container">
        <div class="hop-thankyou__inner">
            <div class="hop-thankyou__icon">&#10003;</div>
            <h1>{{ trans('order.thank_you') }}</h1>
            <p>{{ trans('order.received') }}</p>
            {% if order %}
            <div class="hop-order-summary">
                <div class="hop-order-summary__row"><span>{{ trans('order.number') }}</span><strong>#{{ order.reference_id }}</strong></div>
                <div class="hop-order-summary__row"><span>{{ trans('order.total') }}</span><strong>{{ order.amounts.total.formatted }}</strong></div>
                <div class="hop-order-summary__row"><span>{{ trans('order.status') }}</span><strong>{{ order.status.name }}</strong></div>
            </div>
            {% endif %}
            <div class="hop-thankyou__actions">
                {% if order %}<a href="{{ store.url }}/customer/orders/{{ order.id }}" class="hop-btn hop-btn--outline">{{ trans('order.track') }}</a>{% endif %}
                <a href="{{ store.url }}" class="hop-btn">{{ trans('general.home') }}</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
