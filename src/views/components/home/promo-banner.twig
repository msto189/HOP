<section class="hop-promo">
    <div class="hop-container">
        <div class="hop-promo__inner {% if component.image %}hop-promo__inner--img{% endif %}">
            {% if component.image %}
            <div class="hop-promo__img"><img src="{{ component.image }}" alt="{{ component.title ?? '' }}" loading="lazy"></div>
            {% endif %}
            <div class="hop-promo__body">
                {% if component.title %}<h2 class="hop-promo__title">{{ component.title }}</h2>{% endif %}
                {% if component.description %}<p class="hop-promo__desc">{{ component.description }}</p>{% endif %}
                {% if component.btn_text and component.btn_url %}
                <a href="{{ component.btn_url }}" class="hop-btn hop-btn--outline">{{ component.btn_text }}</a>
                {% endif %}
            </div>
        </div>
    </div>
</section>
