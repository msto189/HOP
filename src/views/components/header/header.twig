<header class="hop-header {% if theme.settings.header_is_sticky %}is-sticky{% endif %}" id="hop-header">
    <div class="hop-header__inner">

        <button class="hop-nav-toggle" id="nav-toggle" aria-label="{{ trans('general.menu') }}" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>

        <a href="{{ store.url }}" class="hop-logo">
            {% if store.logo %}
                <img src="{{ store.logo }}" alt="{{ store.name }}" height="32">
            {% else %}
                <span>{{ store.name }}</span>
            {% endif %}
        </a>

        <nav class="hop-nav" id="hop-nav" aria-label="main navigation">
            <ul>
                {% for category in categories %}
                <li class="{% if category.children is not empty %}has-sub{% endif %}">
                    <a href="{{ category.url }}" class="{% if category.is_active %}active{% endif %}">{{ category.name }}</a>
                    {% if category.children is not empty %}
                    <ul class="hop-subnav">
                        {% for child in category.children %}
                        <li><a href="{{ child.url }}">{{ child.name }}</a></li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                </li>
                {% endfor %}
            </ul>
        </nav>

        <div class="hop-header__actions">
            <button class="hop-action" id="search-btn" aria-label="{{ trans('general.search') }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
            <a href="{{ store.url }}/customer/wishlist" class="hop-action" aria-label="{{ trans('general.wishlist') }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </a>
            <salla-cart-icon>
                <button class="hop-action hop-cart" aria-label="{{ trans('general.cart') }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                    <span class="hop-cart__count">{{ cart.count ?? 0 }}</span>
                </button>
            </salla-cart-icon>
            {% if customer.is_logged_in %}
            <a href="{{ store.url }}/customer/profile" class="hop-action" aria-label="{{ trans('customer.my_account') }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </a>
            {% else %}
            <a href="{{ store.url }}/customer/login" class="hop-action" aria-label="{{ trans('general.login') }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </a>
            {% endif %}
        </div>
    </div>

    <div class="hop-search" id="hop-search" hidden>
        <div class="hop-search__inner">
            <salla-search>
                <input type="search" name="q" placeholder="{{ trans('general.search') }}..." class="hop-search__input" autofocus>
            </salla-search>
            <button onclick="document.getElementById('hop-search').hidden=true" aria-label="close">&#x2715;</button>
        </div>
    </div>

    <div class="hop-drawer" id="hop-drawer" aria-hidden="true">
        <div class="hop-drawer__head">
            <a href="{{ store.url }}" class="hop-logo">{{ store.name }}</a>
            <button id="drawer-close" aria-label="close">&#x2715;</button>
        </div>
        <nav class="hop-drawer__nav">
            <ul>
                <li><a href="{{ store.url }}">{{ trans('general.home') }}</a></li>
                {% for category in categories %}
                <li><a href="{{ category.url }}">{{ category.name }}</a></li>
                {% endfor %}
            </ul>
        </nav>
    </div>
    <div class="hop-overlay" id="hop-overlay"></div>
</header>
