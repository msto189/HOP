{% extends 'layouts/master' %}
{% block content %}
<div class="hop-blog">
    <div class="hop-container">
        <h1 class="hop-page-title">{{ trans('blog.title') }}</h1>
        <div class="hop-blog__grid">
            {% for post in posts %}
            <article class="hop-blog-card">
                {% if post.image %}<a href="{{ post.url }}" class="hop-blog-card__img"><img src="{{ post.image }}" alt="{{ post.title }}" loading="lazy"></a>{% endif %}
                <div class="hop-blog-card__body">
                    <p class="hop-blog-card__date">{{ post.date }}</p>
                    <h2 class="hop-blog-card__title"><a href="{{ post.url }}">{{ post.title }}</a></h2>
                    {% if post.excerpt %}<p class="hop-blog-card__excerpt">{{ post.excerpt }}</p>{% endif %}
                    <a href="{{ post.url }}" class="hop-btn hop-btn--sm hop-btn--outline">{{ trans('blog.read_more') }}</a>
                </div>
            </article>
            {% else %}
            <p class="hop-empty">{{ trans('blog.empty') }}</p>
            {% endfor %}
        </div>
        {% if pagination.total_pages > 1 %}<div class="hop-pagination"><salla-pagination>{{ pagination_html }}</salla-pagination></div>{% endif %}
    </div>
</div>
{% endblock %}
