      "description": null,
      "format": "switch",
      "required": false,
      "value": true,
      "selected": false
    },
    {
      "id": "header_is_sticky",
      "type": "boolean",
      "icon": "sicon-toggle-off",
      "label": "تثبيت الهيدر عند التمرير",
      "description": null,
      "format": "switch",
      "required": false,
      "value": true,
      "selected": true
    },
    {
      "id": "footer_is_dark",
      "type": "boolean",
      "icon": "sicon-toggle-off",
      "label": "الفوتر داكن",
      "description": null,
      "format": "switch",
      "required": false,
      "value": true,
      "selected": true
    },
    {
      "id": "show_announcement_bar",
      "type": "boolean",
      "icon": "sicon-toggle-off",
      "label": "إظهار شريط الإعلان",
      "description": null,
      "format": "switch",
      "required": false,
      "value": true,
      "selected": true
