<article class="product-card fade-in">
  <a href="{{ product.url|default('#') }}" class="product-media">
    <img
      loading="lazy"
      src="{{ product.images[0].url|default('https://images.unsplash.com/photo-1434389677669-e08b4cac3105?q=80&w=1200&auto=format&fit=crop') }}"
      alt="{{ product.name|default('Product') }}"
    />
    {% if theme.settings.enable_product_hover_swap and product.images[1] is defined %}
      <img
        loading="lazy"
        class="hover-image"
        src="{{ product.images[1].url }}"
        alt="{{ product.name|default('Product') }} alternate"
      />
    {% endif %}
  </a>
  <div class="product-meta">
    <h3>{{ product.name|default('Premium Piece') }}</h3>
    <p class="price">{{ product.price|default('$120.00') }}</p>
  </div>
</article>
